{
  "name": "merchant_desktop_app",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm --prefix renderer run dev\" \"wait-on http://localhost:5173 && electronmon .\"",
    "build:ui": "npm --prefix renderer run build",
    "dist": "npm run build:ui && electron-builder --win nsis"
  },
  "keywords": [],
  "author": "Tab Dhey",
  "license": "ISC",
  "description": "Merchant Desktop App",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.newedge.merchantdesktopapp",
    "productName": "Merchant Desktop App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "package.json",
      "!node_modules/.cache/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Merchant Desktop App"
    }
  }
}
